{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Defyland/reportforge-elixir-report-platform/docs/events/report_lifecycle_event.v1.json",
  "title": "ReportForge Report Lifecycle Event v1",
  "type": "object",
  "required": ["event_id", "event_type", "schema_version", "occurred_at", "producer", "organization_id", "report_id", "correlation_id", "payload"],
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "type": "string", "enum": ["report.requested", "report.started", "report.progress_updated", "report.uploaded", "report.completed", "report.failed", "report.cancelled"] },
    "schema_version": { "type": "integer", "const": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "type": "string", "const": "reportforge" },
    "organization_id": { "type": "string" },
    "report_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "payload": { "type": "object" }
  },
  "additionalProperties": false
}
