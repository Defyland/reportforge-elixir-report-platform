{
  "title": "ReportForge API",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP Request Volume",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (method, path, status) (rate(reportforge_http_requests_total[5m]))",
          "legendFormat": "{{method}} {{path}} {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Inflight Reports",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "reportforge_inflight_reports",
          "legendFormat": "queued_or_running"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Reports Created",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (template_name, format, deduplicated) (rate(reportforge_reports_created_total[5m]))",
          "legendFormat": "{{template_name}} {{format}} dedup={{deduplicated}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Report Completion Outcomes",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (status) (rate(reportforge_reports_completed_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    }
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  }
}
